static const int kPuppetResolveRowCount = 1486;

static const std::uint16_t kPuppetResolveSlotOffset[19] = {
    0, 44, 143, 245, 342, 442, 470, 514, 603, 843, 893, 993, 1079, 1207, 1213, 1213, 1237, 1326, 1408,  // offsets
};
static const std::uint8_t kPuppetResolveSlotCount[19] = {
    44, 99, 102, 97, 100, 28, 44, 89, 240, 50, 100, 86, 128, 6, 0, 24, 89, 82, 78
};

inline const T4CPuppetResolveRow *T4CPuppetResolveLookup(
        const std::uint8_t slot, const std::uint16_t pupeq, const bool female) {
    if (slot >= 19) return nullptr;
    const int base = kPuppetResolveSlotOffset[slot];
    const int n = kPuppetResolveSlotCount[slot];
    const std::uint8_t g = female ? 1 : 0;
    for (int i = 0; i < n; ++i) {
        const T4CPuppetResolveRow &r = kPuppetResolveRows[base + i];
        if (r.pupeq == pupeq && r.female == g) return &r;
    }
    // fallback: gender-neutral row (weapons)
    for (int i = 0; i < n; ++i) {
        const T4CPuppetResolveRow &r = kPuppetResolveRows[base + i];
        if (r.pupeq == pupeq && r.female == 0) return &r;
    }
    return nullptr;
}
